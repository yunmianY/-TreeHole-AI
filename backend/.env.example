# LLM 配置 (DeepSeek 兼容 OpenAI API)
LLM_API_KEY=sk-your-wechat-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# JWT 配置
SECRET_KEY=change-me-to-a-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 微信机器人（WeChat Bot）──
# 是否启用微信机器人（true/false）
WECHAT_BOT_ENABLED=false
# 微信端 AI 提供商（deepseek / dusapi），独立于 Web 端 LLM 配置
WECHAT_BOT_PROVIDER=deepseek
WECHAT_BOT_API_KEY=sk-your-wechat-api-key
WECHAT_BOT_BASE_URL=https://api.deepseek.com
WECHAT_BOT_MODEL=deepseek-v4-flash
WECHAT_BOT_PROMPT=你是一个有帮助的AI助手，请用中文简洁地回复。字数尽量少一些

# 数据库
DATABASE_URL=sqlite:///./data/treehole.db
